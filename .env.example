# Local release-signing and notarization configuration.
#
# Copy this file to `.env`, fill in the values locally, then load it with
# `set -a; source .env; set +a` before invoking Installer/build_installer.sh.
# `.env` is intentionally ignored by Git. Do not commit real credentials.
#
# GitHub Actions uses the same values as *Production environment secrets*;
# configure them in GitHub rather than committing a populated .env file.

# Base64-encoded .p12 containing the Developer ID Application and Installer
# certificates. This is used only by the GitHub Actions workflow.
APPLE_CERTIFICATES_P12=
APPLE_CERTIFICATES_P12_PASSWORD=
KEYCHAIN_PASSWORD=

# Apple ID and app-specific password used by `xcrun notarytool`.
APPLE_ID=
APPLE_TEAM_ID=
APPLE_NOTARY_PASSWORD=

# GitHub secret name: APPLE_APP_PASSWORD. Its value is assigned to
# APPLE_NOTARY_PASSWORD by the macOS release workflow.
APPLE_APP_PASSWORD=

# GitHub Actions only: Netlify deploy hook URL.
NETLIFY_BUILD_HOOK_URL=
