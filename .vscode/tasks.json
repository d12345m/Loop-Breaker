{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build VST3 (Debug)",
      "type": "shell",
      "command": "bash gen_build_info.sh && cd Builds/MacOSX && xcodebuild -project LoopBreaker.xcodeproj -scheme \"LoopBreaker - VST3\" -configuration Debug build",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "isBackground": false
    },
    {
      "label": "Build VST3 (Release)",
      "type": "shell",
      "command": "bash gen_build_info.sh && cd Builds/MacOSX && xcodebuild -project LoopBreaker.xcodeproj -scheme \"LoopBreaker - VST3\" -configuration Release build",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "isBackground": false
    },
    {
      "label": "Build AU (Debug)",
      "type": "shell",
      "command": "bash gen_build_info.sh && cd Builds/MacOSX && xcodebuild -project LoopBreaker.xcodeproj -scheme \"LoopBreaker - AU\" -configuration Debug build",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "isBackground": false
    },
    {
      "label": "Build AU (Release)",
      "type": "shell",
      "command": "bash gen_build_info.sh && cd Builds/MacOSX && xcodebuild -project LoopBreaker.xcodeproj -scheme \"LoopBreaker - AU\" -configuration Release build",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "isBackground": false
    },
    {
      "label": "Build All (Debug)",
      "type": "shell",
      "command": "bash gen_build_info.sh && cd Builds/MacOSX && xcodebuild -project LoopBreaker.xcodeproj -scheme \"LoopBreaker - VST3\" -configuration Debug build && xcodebuild -project LoopBreaker.xcodeproj -scheme \"LoopBreaker - AU\" -configuration Debug build",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "isBackground": false
    },
    {
      "label": "Build All (Release)",
      "type": "shell",
      "command": "bash gen_build_info.sh && cd Builds/MacOSX && xcodebuild -project LoopBreaker.xcodeproj -scheme \"LoopBreaker - VST3\" -configuration Release build && xcodebuild -project LoopBreaker.xcodeproj -scheme \"LoopBreaker - AU\" -configuration Release build",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "isBackground": false
    },
    {
      "label": "Build macOS Installer + Package",
      "type": "shell",
      "command": "bash Installer/build_installer.sh --skip-build",
      "group": "build",
      "problemMatcher": [],
      "isBackground": false,
      "dependsOn": "Build All (Release)"
    },
    {
      "label": "Run pluginval (Debug)",
      "type": "shell",
      "command": "bash run_pluginval.sh --debug --strictness 5",
      "group": "test",
      "problemMatcher": [],
      "isBackground": false
    },
    {
      "label": "Run pluginval (Release)",
      "type": "shell",
      "command": "bash run_pluginval.sh --release --strictness 5",
      "group": "test",
      "problemMatcher": [],
      "isBackground": false
    },
    {
      "label": "Run pluginval (Strict)",
      "type": "shell",
      "command": "bash run_pluginval.sh --debug --strictness 10",
      "group": "test",
      "problemMatcher": [],
      "isBackground": false
    },
    {
      "label": "Configure iOS (Xcode)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S", "${workspaceFolder}",
        "-B", "${workspaceFolder}/build-ios",
        "-G", "Xcode",
        "-DJUCE_DIR=${env:HOME}/JUCE",
        "-DCMAKE_SYSTEM_NAME=iOS",
        "-DCMAKE_OSX_SYSROOT=iphoneos",
        "-DCMAKE_OSX_DEPLOYMENT_TARGET=15.0",
        "-DLOOP_BREAKER_BUILD_TESTS=OFF"
      ],
      "problemMatcher": [],
      "isBackground": false
    },
    {
      "label": "Build iOS (Debug, unsigned)",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-project", "${workspaceFolder}/build-ios/LoopBreaker.xcodeproj",
        "-scheme", "LoopBreaker_Standalone",
        "-configuration", "Debug",
        "-destination", "generic/platform=iOS",
        "CODE_SIGNING_ALLOWED=NO",
        "build"
      ],
      "dependsOn": "Configure iOS (Xcode)",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "isBackground": false
    },
    {
      "label": "Build iOS (Release, unsigned)",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-project", "${workspaceFolder}/build-ios/LoopBreaker.xcodeproj",
        "-scheme", "LoopBreaker_Standalone",
        "-configuration", "Release",
        "-destination", "generic/platform=iOS",
        "CODE_SIGNING_ALLOWED=NO",
        "build"
      ],
      "dependsOn": "Configure iOS (Xcode)",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "isBackground": false
    },
    {
      "label": "Open iOS Project in Xcode",
      "type": "shell",
      "command": "open",
      "args": ["${workspaceFolder}/build-ios/LoopBreaker.xcodeproj"],
      "dependsOn": "Configure iOS (Xcode)",
      "problemMatcher": [],
      "isBackground": false
    }
  ]
}
